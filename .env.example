# =============================================
# FIRST IN Q (FiQ) - AI WhatsApp Customer Care
# =============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp Cloud API
WHATSAPP_API_VERSION=v21.0
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# Lipila Payment Gateway (https://docs.lipila.dev)
# Get your API key from https://dashboard.lipila.dev (sandbox) or https://dashboard.lipila.io (production)
LIPILA_API_URL=https://api.lipila.dev
LIPILA_API_KEY=Lsk_your-lipila-secret-key
LIPILA_CALLBACK_URL=https://your-domain.com/api/payments/callback

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=your-app-secret-for-signing
