# =============================================
# FIRST IN Q (FiQ) - AI WhatsApp Customer Care
# =============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp Cloud API
WHATSAPP_API_VERSION=v21.0
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# Lipila Payment Gateway (https://docs.lipila.dev)
# Sandbox: API=https://api.lipila.dev  Dashboard=https://dashboard.lipila.dev
# Production: API=https://blz.lipila.io  Dashboard=https://dashboard.lipila.io
LIPILA_ENVIRONMENT=sandbox
LIPILA_API_KEY=Lsk_your-lipila-secret-key
LIPILA_CALLBACK_URL=https://your-domain.com/api/webhooks/lipila

# Lenco Payment Gateway (Card Collections)
# Sandbox: API=https://sandbox.lenco.co/access/v2  Widget=https://pay.sandbox.lenco.co/js/v1/inline.js
# Production: API=https://api.lenco.co/access/v2  Widget=https://pay.lenco.co/js/v1/inline.js
LENCO_ENVIRONMENT=sandbox
LENCO_SECRET_KEY=993bed87f9d592566a6cce2cefd79363d1b7e95af3e1e6642b294ce5fc8c59f6
NEXT_PUBLIC_LENCO_PUBLIC_KEY=pub-88dd921c0ecd73590459a1dd5a9343c77db0f3c344f222b9


# Retell AI - Voice Agent (https://docs.retellai.com)
RETELL_API_KEY=your-retell-api-key
RETELL_LLM_ID=your-retell-llm-id

# Twilio - Voice Telephony (https://www.twilio.com)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VOICE_NUMBER=+260xxxxxxxxx

# Telnyx - Voice Telephony (cheaper alternative to Twilio for Zambia)
# Dashboard: https://portal.telnyx.com
# Zambia local rate: $0.145/min (with Zambian number) vs Twilio $1.08/min
# Requires: API Key + Voice API Application ID (connection_id) + Phone Number
TELNYX_API_KEY=KEY01your-telnyx-api-key
# Voice API Application ID (connection_id) from Mission Control → Voice → Applications
TELNYX_APP_ID=your-telnyx-app-id
# Your Telnyx phone number in E.164 format
# Get a Zambian (+260) number for local rates — ask Telnyx support if not visible in portal
TELNYX_VOICE_NUMBER=+260xxxxxxxxx
# Voice provider selector: "twilio" | "telnyx" | "web"
# "twilio"  — PSTN calls via Twilio (requires Twilio credentials above)
# "telnyx"  — PSTN calls via Telnyx (requires Telnyx credentials above)
# "web"     — Browser-only WebRTC calls via Retell (no phone numbers, $0 telephony cost)
# When "web", WhatsApp "call me" requests get a link to the web call widget instead.
VOICE_PROVIDER=web

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=your-app-secret-for-signing
